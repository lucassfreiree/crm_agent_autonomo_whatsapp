# ════════════════════════════════════════════════════════════════
#  CRM Agent WhatsApp — Variáveis de Ambiente (TEMPLATE)
#  Copie para .env e preencha. NUNCA commite o .env real.
# ════════════════════════════════════════════════════════════════

# ── Banco de Dados (PostgreSQL via docker-compose) ───────────────
# Em desenvolvimento local, DB_HOST é o nome do serviço do compose.
# Rodando um serviço Node fora do compose (host), use "localhost".
DATABASE_URL="postgresql://crm_user:crm_pass@localhost:5432/crm_db?schema=public"
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass
POSTGRES_DB=crm_db
POSTGRES_PORT=5432

# ── Redis (eventos pub/sub + filas BullMQ) ───────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# ── Segredo para criptografar a API key da IA em repouso ─────────
# Gere com: openssl rand -base64 32
AI_CONFIG_ENCRYPTION_KEY=""

# ════════════════════════════════════════════════════════════════
#  Variáveis das ETAPAS FUTURAS (placeholder — preencher depois)
# ════════════════════════════════════════════════════════════════

# ── Etapa 1: Daemon WhatsApp (Baileys) ──────────────────────────
# Diretório onde a sessão/auth do Baileys será persistida.
WA_AUTH_DIR="./baileys-auth"
# Porta da API REST interna do daemon (POST /send)
WA_DAEMON_PORT=3001
# Rate-limit anti-banimento (mensagens por minuto, delays humanos)
WA_SEND_RATE_PER_MIN=12
WA_SEND_MIN_DELAY_MS=2000
WA_SEND_MAX_DELAY_MS=8000

# ── Etapa 2: Classificador de IA ────────────────────────────────
# O provedor/modelo são lidos da tabela AIProviderConfig (aba Config
# do painel). Estas variáveis controlam apenas comportamento do worker.
AI_CLASSIFY_MIN_MESSAGES=1
AI_CLASSIFY_IDLE_TIMEOUT_MS=30000

# ── Etapa 3: Painel CRM (Next.js) ───────────────────────────────
CRM_PANEL_PORT=3000
# Secret para cookies/sessão do painel. Gere com: openssl rand -base64 32
CRM_SESSION_SECRET=""
