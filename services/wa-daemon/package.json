{
  "name": "@crm/wa-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daemon sempre ligado: conexão WhatsApp via Baileys (QR/pairing code), persiste sessão, grava mensagens no Postgres, publica eventos Redis. API REST interna para o painel.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cacheable/node-cache": "^3.1.1",
    "@crm/db": "workspace:*",
    "@crm/shared-types": "workspace:*",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "6.7.15",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "link-preview-js": "^3.0.13",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
